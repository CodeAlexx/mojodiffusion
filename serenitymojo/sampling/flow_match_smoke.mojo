    var cur = Tensor.from_host(roll_x0, [1, 16, 8, 8], F32, ctx)
    var vel0 = Tensor.from_host(roll_v0, [1, 16, 8, 8], F32, ctx)
    cur = rsched.step(cur, vel0, 0, ctx)
    var vel1 = Tensor.from_host(roll_v1, [1, 16, 8, 8], F32, ctx)
    cur = rsched.step(cur, vel1, 1, ctx)
    var vel2 = Tensor.from_host(roll_v2, [1, 16, 8, 8], F32, ctx)
    cur = rsched.step(cur, vel2, 2, ctx)
    r = h.compare(cur, roll_xfinal, ctx)
    print("3-step rollout final    ", r)
    all_pass = all_pass and r.passed

    print("")
    if all_pass:
        print("ALL FLOW-MATCH PARITY CHECKS PASS")
    else:
