{
  "schema": "serenity.sample_prompts.v1",
  "defaults": {
    "sample_every": 500,
    "sample_at_start": true,
    "save_before_sample": true,
    "precache_required": true,
    "width": 1024,
    "height": 1024,
    "frames": 1,
    "fps": 24,
