# ops_smoke2.mojo — Phase A chunk A2 GPU smoke + parity driver.
#
# Runs EACH new op on the GPU, copies back, and compares to the numpy oracle
# (serenitymojo/parity_oracle/gen_ops2_reference.py, seed=4321) via
# ParityHarness. Prints cos + max_abs for each. Gate: cos >= 0.999.
#
# Also re-tests the EXISTING rms_norm at production column counts D in
# {2560, 3072, 4096} (cols > _TPB=256) to confirm the loop-stride reduction is
# correct at scale (A1 skeptic-bait). For that we generate inputs + reference
# on the fly in-driver (rms_norm has a closed form; no numpy needed).
#
# Storage dtype = F32 throughout for parity cases so op math is isolated from
# BF16/F16 quantization. Small dtype-dispatch smokes cover selected BF16/F16
# storage paths.
#
# Run: pixi run mojo run -I . serenitymojo/ops_smoke2.mojo

from std.math import sqrt
from std.gpu.host import DeviceContext
from serenitymojo.tensor import Tensor
from serenitymojo.io.dtype import STDtype
from serenitymojo.parity import ParityHarness, ParityResult
from serenitymojo.ops.norm import rms_norm, layer_norm, group_norm
from serenitymojo.ops.rope import rope_interleaved, rope_halfsplit
from serenitymojo.ops.activations import silu, gelu, swiglu
from serenitymojo.ops.elementwise import modulate, residual_gate
from serenitymojo.ops.softmax import softmax_lastdim
from serenitymojo.ops.attention import sdpa, sdpa_nomask
from serenitymojo.ops.conv import conv2d


def _lf(*values: Float64) -> List[Float32]:
    var out = List[Float32]()
    for i in range(len(values)):
        out.append(Float32(values[i]))
    return out^


def main() raises:
    var ctx = DeviceContext()
    var h = ParityHarness()
    var all_pass = True

    # ── layer_norm: x[3,6], g[6], b[6], eps=1e-5 ─────────────────────────────
    var x_ln = _lf(
        -0.76652151, 0.96119469, 1.45634699, -0.52979267, -0.26476741, -0.57217133,
        -0.75111347, 2.22821665, 0.65734059, -1.13237751, 0.33018121, 0.13101320,
        0.80145180, -1.46271300, -1.41138971, -1.65312374, -0.14342971, 0.51649004,
    )
    var g_ln = _lf(1.28008747, -1.22513855, -0.77911323, -0.12907887, 0.55540812, 0.41840178)
    var b_ln = _lf(0.32930979, 1.14002395, -0.00801868, 0.76995462, -1.35304487, -0.65235037)
    var y_ln_ref = _lf(
        -0.90180254, -0.18287921, -1.30515730, 0.85798800, -1.55790591, -0.95865762,
        -0.84879982, -1.10866046, -0.30598372, 0.93427110, -1.30870724, -0.69602954,
        2.08216381, 2.25485754, 0.66069359, 0.91215408, -1.12081170, -0.19944787,
    )
    var ln = layer_norm(
        Tensor.from_host(x_ln, [3, 6], STDtype.F32, ctx),
        Tensor.from_host(g_ln, [6], STDtype.F32, ctx),
        Tensor.from_host(b_ln, [6], STDtype.F32, ctx),
        Float32(1e-5), ctx,
    )
    var r = h.compare(ln, y_ln_ref, ctx)
    print("layer_norm     ", r)
    all_pass = all_pass and r.passed

    # ── group_norm NHWC: x[2,2,2,4], g[4], b[4], num_groups=2, eps=1e-5 ──────
    var x_gn = _lf(
        -1.65033615, 0.98659414, 1.74636900, -0.29749674, 0.36506456, -1.47233915, 0.53323632, -1.62450981,
        -1.35767066, -0.76749927, 0.28458712, -1.34405541, -0.98728007, -1.05188274, -0.35707638, -1.28465831,
        1.96584988, 0.16300984, 0.42760614, 0.17308706, -0.90879506, 0.53471649, 2.56963706, 1.30136490,
        0.95198756, -0.74183583, -1.23167956, -0.03830088, 1.13675761, -1.27048588, -0.82739413, -1.93439949,
    )
    var g_gn = _lf(1.46880233, 0.35048935, -0.87163168, 1.10786879)
    var b_gn = _lf(0.11938788, -0.28236213, 0.38225883, 1.37804627)
    var y_gn_ref = _lf(
        -1.40762198, 0.41096857, -1.28985715, 1.37330830, 1.98017788, -0.57534403, -0.29516327, -0.00965798,
        -0.91566420, -0.29262286, -0.09128633, 0.28262162, -0.29305387, -0.40669307, 0.43483809, 0.34452331,
        2.53185129, -0.30419996, 0.14043319, 1.47546327, -1.46076715, -0.18100715, -1.24973249, 2.40616870,
        1.12368929, -0.60408831, 1.21730006, 1.30109143, 1.38031805, -0.77929604, 0.95492113, -0.26298177,
    )
    var gn = group_norm(
        Tensor.from_host(x_gn, [2, 2, 2, 4], STDtype.F32, ctx),
        Tensor.from_host(g_gn, [4], STDtype.F32, ctx),
        Tensor.from_host(b_gn, [4], STDtype.F32, ctx),
        2, Float32(1e-5), ctx,
    )
    r = h.compare(gn, y_gn_ref, ctx)
    print("group_norm     ", r)
    all_pass = all_pass and r.passed

    # ── rope: x[3,8], cos/sin [3,4] ──────────────────────────────────────────
    var x_rope = _lf(
        -0.86208779, -1.08337927, 0.86643302, -2.72878337, 1.06099451, 0.68064255, 0.30065712, 0.52130485,
        1.67311978, -0.17333357, 0.27141023, -0.40175679, 0.91655123, 1.14613831, -1.71302974, -1.03000820,
        -0.10228661, 1.50324476, 0.08846451, -0.84038919, -0.16242278, 0.60746682, -0.55755764, 0.62654555,
    )
    var cos_rope = _lf(
        0.99043453, 0.58761591, 0.34078598, 0.46610013, -0.60201746, 0.96581620, 0.80547434, 0.97989231,
        0.56855106, 0.97843248, 0.78336275, -0.16477983,
    )
    var sin_rope = _lf(
        0.13798350, -0.80914003, 0.94014090, -0.88473195, -0.79848289, -0.25922784, 0.59263062, -0.19952701,
        -0.82264799, -0.20656693, -0.62156481, -0.98633039,
    )
    var y_int_ref = _lf(
        -0.70435303, -1.19197023, -1.69883800, -2.30454206, -0.27832785, 1.22943783, 0.60135138, -0.02302070,
        -1.14565122, -1.23160768, 0.15798587, -0.45838031, 0.05902183, 1.46636128, -1.88409913, -0.66750145,
        1.17848611, 0.93881732, -0.08704007, -0.84053791, 0.25034404, 0.57682317, 0.70985514, 0.44669399,
    )
    var y_half_ref = _lf(
        -1.00024128, -0.08587575, 0.01260817, -0.81067121, 0.93189174, 1.27656186, 0.91702884, 2.65722203,
        -0.27539682, 0.12970260, 1.23380792, -0.59919286, -1.88773739, 1.15189183, -1.21895552, -0.92913580,
        -0.19177194, 1.59630609, -0.27725840, 0.75646007, -0.00819976, 0.28384459, -0.49175629, 0.72565937,
    )
    var ri = rope_interleaved(
        Tensor.from_host(x_rope, [3, 8], STDtype.F32, ctx),
        Tensor.from_host(cos_rope, [3, 4], STDtype.F32, ctx),
        Tensor.from_host(sin_rope, [3, 4], STDtype.F32, ctx),
        ctx,
    )
    r = h.compare(ri, y_int_ref, ctx)
    print("rope_interleav ", r)
    all_pass = all_pass and r.passed
    var rh = rope_halfsplit(
        Tensor.from_host(x_rope, [3, 8], STDtype.F32, ctx),
        Tensor.from_host(cos_rope, [3, 4], STDtype.F32, ctx),
        Tensor.from_host(sin_rope, [3, 4], STDtype.F32, ctx),
        ctx,
    )
    r = h.compare(rh, y_half_ref, ctx)
    print("rope_halfsplit ", r)
    all_pass = all_pass and r.passed

    # ── activations: silu/gelu x[12]; swiglu gate/up[10] ─────────────────────
    var x_act = _lf(
        -0.22459650, -0.26417482, 0.89741266, 0.48750576, 1.14257765, -1.57970679,
        0.99596012, -0.32653898, 0.48041219, -0.47319448, 1.11898923, 0.04298194,
    )
    var silu_ref = _lf(
        -0.09974009, -0.11474109, 0.63753760, 0.30201894, 0.86624819, -0.26987237,
        0.72731334, -0.13684693, 0.29682037, -0.18164064, 0.84349543, 0.02195276,
    )
    var gelu_ref = _lf(
        -0.09234289, -0.10456789, 0.73149973, 0.33492514, 0.99772036, -0.09037319,
        0.83681893, -0.12147868, 0.32884306, -0.15050752, 0.97156906, 0.02222777,
    )
    var s = silu(Tensor.from_host(x_act, [12], STDtype.F32, ctx), ctx)
    r = h.compare(s, silu_ref, ctx)
    print("silu           ", r)
    all_pass = all_pass and r.passed
    var ge = gelu(Tensor.from_host(x_act, [12], STDtype.F32, ctx), ctx)
    r = h.compare(ge, gelu_ref, ctx)
    print("gelu(tanh)     ", r)
    all_pass = all_pass and r.passed

    var gate_sg = _lf(
        1.00894189, -1.93181741, -0.59588110, -0.32062230, 0.42066294, -2.03063488,
        0.72318977, -0.19703862, -0.73956037, 1.89812219,
    )
    var up_sg = _lf(
        1.18383384, -0.95860994, -0.10082640, -0.49759597, -0.16403098, -0.19733638,
        0.72027439, 0.49698251, 2.08708596, -0.24742423,
    )
    var swiglu_ref = _lf(
        0.87528628, 0.23435199, 0.02134581, 0.06709056, -0.04165235, 0.04649283,
        0.35072336, -0.04415418, -0.49871370, -0.40843722,
    )
    var sg = swiglu(
        Tensor.from_host(gate_sg, [10], STDtype.F32, ctx),
        Tensor.from_host(up_sg, [10], STDtype.F32, ctx),
        ctx,
    )
    r = h.compare(sg, swiglu_ref, ctx)
    print("swiglu         ", r)
    all_pass = all_pass and r.passed

    # ── elementwise: modulate, residual_gate. x[3,5], params[5] ──────────────
    var x_md = _lf(
        1.24737048, 0.45296898, 0.76302075, -0.17632575, 1.57121873,
        -0.14244455, 1.89017165, -2.19326496, -0.51373166, -0.27969205,
        1.14431238, -1.09749126, -2.06098604, -1.12743998, -0.65232170,
    )
    var scale_md = _lf(1.47827446, -0.15567955, 1.57088423, -0.92905605, -1.13205838)
    var shift_md = _lf(0.81206876, -0.52569252, -0.36586067, 0.15610816, -0.22985739)
    var modulate_ref = _lf(
        3.90339494, -0.14324155, 1.59577727, 0.14359891, -0.43734998,
        0.45905209, 1.07021809, -6.00449085, 0.11966200, -0.19292170,
        3.64798880, -1.45232677, -5.66441679, 0.07612311, -0.14371285,
    )
    var md = modulate(
        Tensor.from_host(x_md, [3, 5], STDtype.F32, ctx),
        Tensor.from_host(scale_md, [5], STDtype.F32, ctx),
        Tensor.from_host(shift_md, [5], STDtype.F32, ctx),
        ctx,
    )
    r = h.compare(md, modulate_ref, ctx)
    print("modulate       ", r)
    all_pass = all_pass and r.passed

    var gate_rg = _lf(-1.50163460, -0.46151379, 0.16049643, 0.32697007, -1.81485212)
    var y_rg = _lf(
        -0.07895260, -0.32448673, 0.76422799, 0.50040334, 1.58233428,
        -0.46653828, -0.31604001, -0.03019099, 1.34486735, 0.99671674,
        -1.67071617, -0.12722592, 0.95356417, -1.21468925, 0.14113611,
    )
    var resgate_ref = _lf(
        1.36592841, 0.60272408, 0.88567662, -0.01270884, -1.30048394,
        0.55812550, 2.03602839, -2.19811058, -0.07400030, -2.08858538,
        3.65311766, -1.03877473, -1.90794241, -1.52460694, -0.90846288,
    )
    var rg = residual_gate(
        Tensor.from_host(x_md, [3, 5], STDtype.F32, ctx),
        Tensor.from_host(gate_rg, [5], STDtype.F32, ctx),
        Tensor.from_host(y_rg, [3, 5], STDtype.F32, ctx),
        ctx,
    )
    r = h.compare(rg, resgate_ref, ctx)
    print("residual_gate  ", r)
    all_pass = all_pass and r.passed

    # ── softmax: x[3,7] ──────────────────────────────────────────────────────
    var x_sm = _lf(
        0.57884830, 0.70046973, 0.08923353, -0.21928169, -0.01934204, -0.98944461, 1.21357977,
        -1.06071866, -0.45294866, 1.39678895, -2.14122844, 1.03511286, -0.20199610, -0.29763743,
        -0.97157264, 0.38640568, -0.84085518, -2.19931555, 0.10088499, 0.00875490, -2.33943081,
    )
    var softmax_ref = _lf(
        0.17131852, 0.19347453, 0.10499468, 0.07712245, 0.09419189, 0.03570289, 0.32319504,
        0.03637866, 0.06680327, 0.42474532, 0.01234773, 0.29583848, 0.08585886, 0.07802766,
        0.08221346, 0.31967261, 0.09369422, 0.02408468, 0.24027324, 0.21912597, 0.02093581,
    )
    var sm = softmax_lastdim(Tensor.from_host(x_sm, [3, 7], STDtype.F32, ctx), ctx)
    r = h.compare(sm, softmax_ref, ctx)
    print("softmax        ", r)
    all_pass = all_pass and r.passed

    # ── sdpa: BSHD B=1,S=4,H=2,Dh=8, full attention (zero mask) ──────────────
    var q_sdpa = _lf(
        -0.81689179, 1.15590799, 0.38318831, 1.04243410, -0.92184043, -0.71423078, -0.14956726, -1.18351817,
        0.48571938, 1.52392220, 1.69382155, 0.42992994, -0.05312561, 0.63665205, -0.53323185, 1.74774516,
        1.39044535, 1.50824547, -0.00904297, -0.32359669, -1.58767104, -0.94539768, -0.90470666, -1.73088849,
        -1.04945850, -0.29859689, -1.47469854, 0.51381469, -0.16393870, 0.26097959, -1.43310738, 0.04597096,
        1.70797443, 0.01535287, -0.79463726, 0.29721794, 0.24701716, -0.61518919, 0.79888350, -0.75056976,
        -0.14320244, -1.66674304, -1.30500257, 0.13228826, -0.20083365, 0.00211959, 0.52722257, -0.25911781,
        -0.20451485, -0.00656543, 0.16429035, -0.02622447, -0.87010580, 0.86420500, -0.59214723, -0.39663529,
        1.78439867, 1.34119916, -0.57512379, 1.63703465, -1.79591632, 0.68426526, -0.42365831, 0.56346852,
    )
    var k_sdpa = _lf(
        0.37468085, 1.67026675, 0.78969163, -0.86411947, -1.17559934, 0.36563203, -1.11632538, -1.07300210,
        -1.70765936, -0.22048497, -0.79371411, -0.93318045, -0.00057950, 2.73248363, 0.01258433, 1.05689025,
        -0.18576929, 2.68544388, 0.48305538, -0.10057122, 0.09326154, -0.54958856, 1.00701976, -0.52812845,
        0.26531568, 0.21333763, -1.05244601, -0.03309926, 0.02047296, 0.36339363, 1.42910492, -1.18918991,
        -0.17117657, -0.78565103, -0.20488752, -0.52849686, 0.03965535, -0.63422775, -1.14558864, 1.43341374,
        0.85839128, -1.03584778, -1.44638896, -1.04916155, 0.15638307, 0.43911904, -0.06810242, -0.79746044,
        -0.39156973, -0.30056930, 1.08444166, -0.49031690, 0.90270472, 0.66333336, -0.17599037, -0.34420729,
        0.27378806, 0.26510289, 0.46666974, -1.02992594, 0.55880165, -0.52117848, 1.53799021, 0.75302392,
    )
    var v_sdpa = _lf(
        -0.86327380, 0.88058627, 0.36491355, -1.04376781, 1.11567926, -1.13628566, 0.77673292, -0.02652065,
        0.38094866, 0.41543123, -2.07912612, 0.65674782, 0.34079742, 0.07885572, 2.04721522, 0.28180766,
        -0.59380728, -0.25086486, -1.05987298, 1.50433373, 0.57414806, -0.46833557, 0.66046113, 0.71702212,
        0.59406477, 0.24265592, -0.14646281, 0.70124960, -0.90200895, -0.08484521, -1.85398412, -2.17040253,
        -1.48646510, 1.01962960, 0.02844678, 2.06882668, -0.86976343, -0.73512608, 1.19284332, 1.17687047,
        1.80278325, -0.94512582, -1.15956104, 0.19352853, 1.18902314, 0.13528645, -0.14371708, 0.51042771,
        -1.99326122, 0.24916653, 0.80605865, 2.93707824, 0.45146513, 1.50824106, -0.48947570, -1.85006857,
        2.61241961, 1.53924274, 1.73007846, 0.26021490, -1.07385552, -0.57265049, -0.78034741, 0.29221544,
    )
    var out_sdpa_ref = _lf(
        -0.85122693, 0.27144620, -0.32554847, 0.70161575, 0.69614089, -0.56767935, 0.63513148, 0.25274706,
        1.50076473, 0.84897321, -0.12137388, 0.45333725, -0.36603826, -0.23159531, 0.31936672, 0.10359954,
        -0.84531420, 0.62689489, 0.06192525, -0.33663464, 0.93950009, -0.92396790, 0.73249352, 0.11872242,
        0.87968296, 0.08223855, -1.41918123, 0.52342337, 0.34044212, 0.04425267, 0.83557993, 0.02038896,
        -1.04097462, 0.30824664, -0.22798294, 1.23706460, 0.44723028, -0.33268294, 0.57825255, 0.17790709,
        1.28200877, -0.11627134, -0.79171365, 0.42575192, 0.24752806, -0.00372501, -0.21767028, -0.25976703,
        -1.17345953, 0.60233378, 0.19802162, 0.70915908, 0.56227410, -0.39790851, 0.55396682, -0.11458774,
        1.15257931, 0.16460173, -0.49500832, 0.50049281, -0.16398118, -0.06933544, -0.52677983, -0.67066044,
    )
    var mask_z = List[Float32]()
    for _ in range(1 * 2 * 4 * 4):
        mask_z.append(Float32(0.0))
    var out_sdpa = sdpa[1, 4, 2, 8](
        Tensor.from_host(q_sdpa, [1, 4, 2, 8], STDtype.F32, ctx),
        Tensor.from_host(k_sdpa, [1, 4, 2, 8], STDtype.F32, ctx),
        Tensor.from_host(v_sdpa, [1, 4, 2, 8], STDtype.F32, ctx),
        Tensor.from_host(mask_z, [1, 2, 4, 4], STDtype.F32, ctx),
        Float32(0.35355339), ctx,
    )
    r = h.compare(out_sdpa, out_sdpa_ref, ctx)
    print("sdpa(flash)    ", r)
    all_pass = all_pass and r.passed

    var out_sdpa_nomask = sdpa_nomask[1, 4, 2, 8](
        Tensor.from_host(q_sdpa, [1, 4, 2, 8], STDtype.F32, ctx),
        Tensor.from_host(k_sdpa, [1, 4, 2, 8], STDtype.F32, ctx),
        Tensor.from_host(v_sdpa, [1, 4, 2, 8], STDtype.F32, ctx),
        Float32(0.35355339),
        ctx,
    )
    r = h.compare(out_sdpa_nomask, out_sdpa_ref, ctx)
    print("sdpa(nomask)  ", r)
    all_pass = all_pass and r.passed

    # ── conv2d NHWC: x[1,5,5,3], filt RSCF[3,3,3,4], bias[4], stride1 pad1 ────
    var x_cv = _lf(
        -2.25481272, -1.28533018, -0.05268545, 0.48989141, -0.71580398, 0.77114516, -1.23667443, -1.13676643, -0.11250859, 0.24453582, 1.48721159, 0.92254633, 0.13865069, -1.42227876, 1.32908392,
        -0.95258814, 1.36845958, 0.88096470, 1.22654152, -1.62262917, 2.46792459, 0.83635050, -1.66317821, -1.45327902, 0.51536250, 1.50659263, -1.04691815, 0.58442932, -1.65200710, 0.33752713,
        0.50624698, 0.42571354, -1.39710677, 1.20550811, 0.47123769, 1.22649658, -0.77356225, -1.88325286, 0.16380884, 2.07706118, 0.89327139, -0.15445165, -1.34333408, -0.53179961, -0.64905190,
        -0.92859387, 0.11722708, 0.71470457, -0.09044559, 0.99683332, -0.31278074, 0.22606644, 1.55735266, 0.15902197, 0.54221833, 0.32557556, -0.47029823, -1.61259639, 1.36255884, 1.79547298,
        -1.87314308, 1.15409184, -0.88309658, -2.03185391, -1.25978208, -0.63715196, -0.72993112, 0.52467090, -1.02061689, -0.96280396, 0.88510567, -1.89826512, -0.19768447, 1.27785790, -0.82630295,
    )
    var filt_cv = _lf(
        0.90917295, 0.93896949, -0.84148049, -1.28790450, -0.06225993, 0.53290570, 1.06024492, -1.21979594, 0.50112295, -0.13247301, -1.36773598, -0.34355909,
        0.16832103, 0.13907738, 2.26235199, -0.21337681, 0.08478646, -0.46159527, -0.97913122, 0.91560608, -0.31598064, 2.54149985, 0.39685649, 1.08086121,
        0.25955334, 0.35006416, 1.15931010, -1.25016820, -0.40685284, 0.59883624, -0.83515364, -1.42291462, -0.13087155, -0.97581565, 0.19314098, -0.56852520,
        -1.12236154, 0.06046905, -0.06600413, 1.19443119, 0.80301017, 1.57974946, -1.03214884, 0.51185262, 1.13477361, -0.62933016, 0.82225430, -0.73699111,
        0.98191595, 1.81648779, 0.75769079, 0.12817310, 0.56027740, 0.26389375, 0.08838232, -0.29263446, 0.94187796, 0.89328283, 0.65512884, -0.60658896,
        -0.01534470, 0.42846537, -0.09321933, 2.18430829, 0.17230138, 1.03907847, 0.50274336, 1.09847605, 0.28879315, -1.02049637, -0.33080748, 0.76788282,
        0.78315395, -0.21085520, 1.26925015, 0.40289187, 0.34691438, -0.38983324, 0.42982006, -0.60009962, -0.33061612, 1.32577312, 0.29428947, 0.81586891,
        -0.03007907, 1.67430294, 0.89053535, 0.67531955, 0.51402390, 0.58766633, 2.10792112, 0.33086270, 0.14828838, -0.33985057, -1.65074742, -1.72325969,
        0.18471935, -0.52436000, 0.19929723, -0.18345630, -0.34221336, 0.29501441, -0.69655687, 0.64328796, -0.29671907, 1.69947290, 1.42160535, -0.27449897,
    )
    var bias_cv = _lf(1.19523644, 0.30957577, 0.07451941, -0.80403429)
    var out_cv_ref = _lf(
        -0.78443265, -3.51114106, 3.02247500, -3.46395802, 3.31828141, -4.33288527, -5.60364962, -13.62031174, -2.11617494, -0.25746885, -0.48785126, 9.12731266, 5.35696697, -2.17508817, 8.01935482, -2.44508791, 4.20870972, 0.96598446, -2.39343286, -3.08703303,
        1.81018281, -1.65167499, 1.06551075, 2.78143930, 6.04841900, 4.41830397, 5.48165083, 0.46991283, -0.36344635, -3.33431220, -3.71099734, -2.39211535, -4.16678238, -0.31080005, 1.86431766, 9.81447983, 2.33803225, 5.92836475, 2.21448636, -0.42328435,
        1.29384661, -3.54651761, -3.50905538, 4.78099585, 0.59183609, 12.72056293, 8.55659866, 0.87351245, 3.92309022, -0.70232308, -1.21282423, -0.44472611, 3.78283858, 1.39647269, 8.97701931, -2.46396089, -1.41227651, -1.46381736, 2.22962070, -4.88207817,
        2.39198232, -6.10801125, 3.66667891, -4.46092987, 2.29435158, -2.59128618, -0.99343491, 2.08829188, 2.83927083, 4.94909048, -5.59925652, -5.10047531, 3.26685977, -2.97039461, 0.94695401, 8.56583691, 3.59569740, -0.91520154, -1.49326444, -6.70565987,
        -1.95938063, -2.60298514, -4.98417568, -7.20700741, -1.19300628, -2.05845284, -5.50245667, -4.29454184, -0.13529003, -0.00910595, 1.84873426, -5.93880796, -1.72736573, -1.13773632, -2.91468024, -3.06363225, 0.08984768, 6.53913927, -6.65219927, 2.59838295,
    )
    var out_cv = conv2d[1, 5, 5, 3, 3, 3, 4, 1, 1, 1, 1](
        Tensor.from_host(x_cv, [1, 5, 5, 3], STDtype.F32, ctx),
        Tensor.from_host(filt_cv, [3, 3, 3, 4], STDtype.F32, ctx),
        Optional[Tensor](Tensor.from_host(bias_cv, [4], STDtype.F32, ctx)),
        ctx,
    )
    r = h.compare(out_cv, out_cv_ref, ctx)
    print("conv2d         ", r)
    all_pass = all_pass and r.passed

    # ── conv2d narrow bias dispatch: zero conv output + BF16/F16 bias add ─────
    var conv_bias_ref = _lf(
        1.5, -2.25,
        1.5, -2.25,
        1.5, -2.25,
        1.5, -2.25,
    )
    var out_cv_bf16 = conv2d[1, 2, 2, 1, 1, 1, 2, 1, 1, 0, 0](
        Tensor.from_host(_lf(0.0, 0.0, 0.0, 0.0), [1, 2, 2, 1], STDtype.BF16, ctx),
        Tensor.from_host(_lf(0.0, 0.0), [1, 1, 1, 2], STDtype.BF16, ctx),
        Optional[Tensor](Tensor.from_host(_lf(1.5, -2.25), [2], STDtype.BF16, ctx)),
        ctx,
    )
    if out_cv_bf16.dtype() != STDtype.BF16:
        raise Error("conv2d bf16 bias smoke: output dtype mismatch")
    r = h.compare(out_cv_bf16, conv_bias_ref, ctx)
    print("conv2d bf16 bias", r)
    all_pass = all_pass and r.passed

    var out_cv_f16 = conv2d[1, 2, 2, 1, 1, 1, 2, 1, 1, 0, 0](
        Tensor.from_host(_lf(0.0, 0.0, 0.0, 0.0), [1, 2, 2, 1], STDtype.F16, ctx),
        Tensor.from_host(_lf(0.0, 0.0), [1, 1, 1, 2], STDtype.F16, ctx),
        Optional[Tensor](Tensor.from_host(_lf(1.5, -2.25), [2], STDtype.F16, ctx)),
        ctx,
    )
    if out_cv_f16.dtype() != STDtype.F16:
        raise Error("conv2d f16 bias smoke: output dtype mismatch")
    r = h.compare(out_cv_f16, conv_bias_ref, ctx)
    print("conv2d f16 bias ", r)
    all_pass = all_pass and r.passed

    # ── rms_norm at scale: D in {2560, 3072, 4096} (cols > _TPB=256) ─────────
    # Closed-form reference computed in-driver (no numpy). Inputs are a simple
    # deterministic sequence so the loop-stride reduction is the only thing
    # being tested.
    print("")
    print("--- rms_norm at scale (A1 skeptic-bait) ---")
    var dims = [2560, 3072, 4096]
    for di in range(len(dims)):
        var D = dims[di]
        var xv = List[Float32]()
        var gv = List[Float32]()
        var ss: Float64 = 0.0
        for i in range(D):
            # bounded, sign-alternating sequence
            var xi = Float32(0.5) + Float32(i % 17) * Float32(0.1)
            if i % 2 == 1:
                xi = -xi
            xv.append(xi)
            gv.append(Float32(0.25) + Float32(i % 5) * Float32(0.1))
            ss += Float64(xi) * Float64(xi)
        var eps = Float64(1e-6)
        var inv = 1.0 / sqrt(ss / Float64(D) + eps)
        var refv = List[Float32]()
        for i in range(D):
            refv.append(Float32(Float64(xv[i]) * inv * Float64(gv[i])))
        var yt = rms_norm(
            Tensor.from_host(xv, [1, D], STDtype.F32, ctx),
            Tensor.from_host(gv, [D], STDtype.F32, ctx),
            Float32(1e-6), ctx,
        )
        var rr = h.compare(yt, refv, ctx)
        print("rms_norm D=", D, "  ", rr)
        all_pass = all_pass and rr.passed

    print("")
    if all_pass:
        print("ALL PARITY GATES PASSED (cos >= 0.999)")
    else:
        print("PARITY FAILURE")
        raise Error("ops_smoke2 parity gate failed")
