    },
    {
      "id": "portrait_studio",
      "prompt": "trigger word, same subject in a second validation setting",
      "seed": 43,
      "caps": {
        "positive": "/path/to/precache/portrait_studio_pos.bin",
        "negative": "/path/to/precache/portrait_studio_neg.bin"
      }
    }
  ]
}
